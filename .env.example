# Stellar / Soroban Configuration
# The network to use: 'testnet' or 'mainnet'
STELLAR_NETWORK=testnet

# Horizon API URL for the selected network
HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC URL for smart contract interactions
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase used for signing transactions
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Smart Contract ID
# The deployed address of the VacciChain Soroban contract
VACCINATIONS_CONTRACT_ID=

# Backend Configuration
# Secret key for admin-level operations (e.g., adding issuers)
ADMIN_SECRET_KEY=

# Public key for admin-level operations
ADMIN_PUBLIC_KEY=

# Secret key for the SEP-10 authentication server
SEP10_SERVER_KEY=

# Secret key for an authorized issuer (used in tests/scripts)
ISSUER_SECRET_KEY=

# Secret for signing JWT tokens
JWT_SECRET=

# Port for the Node.js backend
PORT=4000

# Python Service Configuration
# Port for the Python analytics service
ANALYTICS_PORT=8001
